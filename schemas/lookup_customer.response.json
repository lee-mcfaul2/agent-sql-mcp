{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["customer"],
  "properties": {
    "customer": {
      "type": "object",
      "required": ["id", "name", "email", "created_at", "region"],
      "properties": {
        "id":         { "type": "integer" },
        "name":       { "type": "string" },
        "email":      { "type": "string" },
        "phone":      { "type": ["string", "null"] },
        "address":    { "type": ["string", "null"] },
        "created_at": { "type": "string", "format": "date-time" },
        "region":     { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
