{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["transactions"],
  "properties": {
    "transactions": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": ["id", "customer_id", "amount_cents", "kind", "created_at"],
        "properties": {
          "id":           { "type": "integer" },
          "customer_id":  { "type": "integer" },
          "amount_cents": { "type": "integer" },
          "kind":         { "type": "string", "enum": ["payment", "refund", "chargeback"] },
          "created_at":   { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
